<?xml version="1.0" encoding="utf-8"?>
<!--
  Inkwell Android app manifest.

  Declares INTERNET for AT Protocol and Constellation API access,
  POST_NOTIFICATIONS for background content-update polling (WorkManager),
  and the OAuth redirect URI (uk.ewancroft.inkwell:/callback).

  The autoVerify on the OAuth intent-filter enables Android Automatic
  Link Handling so the OS routes the OAuth callback back to Inkwell
  without a browser redirect page.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".InkwellApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Inkwell">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              OAuth redirect: captures the PDS authorization callback.
              Uses scheme-only filter (no host) because the redirect URI
              is uk.ewancroft.inkwell:/callback (single slash, matching
              the client-metadata.json served by inkwell.ewancroft.uk).
              Since the URI has no authority component, Android would
              not match a host-based intent filter; we match on scheme
              + path instead.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="uk.ewancroft.inkwell" />
            </intent-filter>
        </activity>
    </application>
</manifest>
