<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Dark variant for when the system is in dark mode at launch.
      The Compose UI takes over theming once it loads.
    -->
    <style name="Theme.Inkwell" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/paper_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
